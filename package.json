{
  "name": "template-repo-mb-single",
  "version": "1.0.0",
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "ios:prebuild": "expo prebuild --platform ios --non-interactive",
    "ios:build": "expo run:ios",
    "web": "expo start --web",
    "doctor": "npx expo-doctor",
    "test": "npm run test:unit",
    "test:unit": "jest --coverage --ci --passWithNoTests",
    "lint": "eslint . --max-warnings=0",
    "typecheck": "tsc --noEmit",
    "verify": "npm run lint && npm run typecheck && npm test && npm run doctor",
    "android:prebuild": "expo prebuild --platform android --non-interactive",
    "maestro:validate": "tsx ./scripts/validate-maestro-flows.ts",
    "maestro:test": "maestro test .maestro",
    "maestro:test:android": "maestro test .maestro/smoke-android.yaml",
    "maestro:test:ios": "maestro test .maestro/smoke-ios.yaml",
    "test:e2e": "npm run maestro:validate && npm run maestro:test"
  },
  "dependencies": {
    "@react-navigation/native": "^7.2.0",
    "@react-navigation/native-stack": "^7.14.7",
    "expo": "~55.0.8",
    "expo-build-properties": "^55.0.10",
    "expo-constants": "~55.0.9",
    "expo-status-bar": "~55.0.4",
    "react": "19.2.0",
    "react-native": "0.83.2",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0"
  },
  "devDependencies": {
    "@types/jest": "~29.5.14",
    "@types/node": "^25.5.0",
    "@types/react": "~19.2.14",
    "@typescript-eslint/parser": "^8.57.2",
    "eslint": "^9.39.4",
    "eslint-config-expo": "^55.0.0",
    "eslint-import-resolver-typescript": "^4.4.4",
    "jest": "~29.7.0",
    "jest-expo": "~55.0.11",
    "jiti": "^2.6.1",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "~5.9.2"
  },
  "engines": {
    "node": ">=20"
  },
  "private": true
}
