{
  "name": "template-repo-mb-single",
  "version": "1.0.0",
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "test": "npm run test:unit",
    "test:unit": "jest --coverage --ci --passWithNoTests",
    "lint": "eslint . --max-warnings=0",
    "typecheck": "tsc --noEmit",
    "android:prebuild": "expo prebuild --platform android --non-interactive",
    "detox:build": "detox build --configuration android.emu.debug",
    "detox:test": "detox test --configuration android.emu.debug --headless",
    "test:e2e": "npm run detox:test"
  },
  "dependencies": {
    "@react-navigation/native": "^7.1.18",
    "@react-navigation/native-stack": "^7.3.25",
    "expo": "~54.0.33",
    "expo-build-properties": "^1.0.10",
    "expo-constants": "~18.0.9",
    "expo-status-bar": "~3.0.9",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "react-native-safe-area-context": "5.6.0",
    "react-native-screens": "~4.16.0"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/react": "~19.1.0",
    "detox": "16.5.0",
    "eslint": "^9.39.3",
    "eslint-config-expo": "^10.0.0",
    "jest": "^29.7.0",
    "jest-expo": "^54.0.17",
    "typescript": "~5.9.2"
  },
  "private": true
}
